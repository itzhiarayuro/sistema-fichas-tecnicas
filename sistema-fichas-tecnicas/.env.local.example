# Firebase Configuration (for Catastro UT Star Integration)
# Place these in .env.local

# Next.js Public Client side (Optional if needed)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Server side ONLY (Firebase Admin)
# Stringified JSON of your service account key file
# Get it from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'

# Google Drive API (If photos are in Drive)
GOOGLE_DRIVE_API_KEY=
